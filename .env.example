# ==============================
# 🔐 VARIABLES DE ENTORNO - EJEMPLO
# ==============================
# Copia este archivo como .env y configura los valores apropiados para tu entorno

# ==============================
# 📧 CONFIGURACIÓN DE EMAIL
# ==============================
# Email del administrador para recibir notificaciones de comentarios y respuestas
# En desarrollo:
ADMIN_EMAIL=admin@gmail.com
# En producción:
# ADMIN_EMAIL=admin@tudominio.com

# ==============================
# 🔐 CONFIGURACIÓN DE SEGURIDAD
# ==============================
# Google reCAPTCHA (opcional)
# RECAPTCHA_SECRET=tu_recaptcha_secret_key

# ==============================
# 🗄️ CONFIGURACIÓN DE BASE DE DATOS
# ==============================
# Para MySQL en producción:
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=agora_db
# DB_USERNAME=agora_user
# DB_PASSWORD=tu_password_seguro

# ==============================
# 🔑 CONFIGURACIÓN JWT
# ==============================
# Rutas a las claves privadas y públicas (opcional, se usan las por defecto si no se especifican)
# ACCESS_TOKEN_PRIVATE_KEY_PATH=ruta/a/access-token-private.key
# ACCESS_TOKEN_PUBLIC_KEY_PATH=ruta/a/access-token-public.key
# REFRESH_TOKEN_PRIVATE_KEY_PATH=ruta/a/refresh-token-private.key
# REFRESH_TOKEN_PUBLIC_KEY_PATH=ruta/a/refresh-token-public.key

# ==============================
# 📨 CONFIGURACIÓN DE KAFKA (OPCIONAL)
# ==============================
# Configuración de Kafka para notificaciones
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_CONSUMER_GROUP_ID=agora-comment-group

# ==============================
# 🌍 CONFIGURACIÓN DEL SERVIDOR
# ==============================
# Puerto del servidor (opcional, por defecto 8080)
# SERVER_PORT=8080

# Perfil activo (dev, prod, staging)
# SPRING_PROFILES_ACTIVE=dev

# ==============================
# 📝 INSTRUCCIONES DE USO
# ==============================
# 1. Copia este archivo como .env: cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. Nunca subas el archivo .env a git (está en .gitignore)
# 4. En producción, configura estas variables en tu servidor/contenedor
# 5. Para Docker: usa -e VARIABLE=valor o --env-file .env
# 6. Para Kubernetes: usa ConfigMaps y Secrets